# 环境变量示例文件，复制一份命名为 .env 并修改其中的值以适应你的环境
# The path on your host machine where you want to store downloaded audio and cover images.
DOWNLOAD_PATH=/volume1/yoto
# Timezone
TZ=America/Los_Angeles

# Optional: Set the user and group IDs for the container to match your host system's permissions.
PUID=1031
PGID=100

# Optional: Discord webhook URL for download notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url